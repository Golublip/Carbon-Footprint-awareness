# Environment Configuration Example
# Copy this file to '.env' and fill in your values.

# Optional: Add your Google Gemini Developer API Key to activate real-time AI Sustainability Coaching.
# If omitted or invalid, the coach falls back on a realistic, localized heuristics engine.
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Application Mode
VITE_APP_MODE=development
